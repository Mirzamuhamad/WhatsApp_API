APP_NAME="WA Gateway Self Hosted"
APP_ENV=local
APP_PORT=3000
APP_URL=http://localhost:3000
APP_TRUST_PROXY=0

# Comma separated keys. Dashboard can exchange one key for a JWT at /api/auth/login.
API_KEYS=isi-api-key-anda
JWT_SECRET=isi-jwt-secret-anda
JWT_EXPIRES_IN=12h
IP_WHITELIST=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=wa_gateway

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

STORAGE_DIR=storage
AUTH_DIR=storage/auth
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_MB=25

WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_INBOUND_PUBLIC=false
