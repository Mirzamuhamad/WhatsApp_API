{
  "name": "wa-gateway-self-hosted",
  "version": "1.0.0",
  "description": "Self-hosted WhatsApp API gateway with Baileys, Express, MySQL, Redis, and Socket.IO.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --config nodemon.json src/server.js",
    "db:migrate": "node src/scripts/migrate.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "pdf-parse": "^2.4.5",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "read-excel-file": "^9.1.1",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "write-excel-file": "^4.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
